// Ce bloc s'exécute côté serveur - rien de sensible n'est exposé
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pointage - Ecole de la mosquée Al'Ihsane</title>
    <style is:global>
      :root { color-scheme: light; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #efefef; min-height: 100vh; color: #1f2937; }
      .wrap { max-width: 480px; margin: 0 auto; padding: 1rem; }
      .card { background: #f3f3f2; border-radius: 10px; overflow: hidden; border: 1px solid #d5d5d2; }
      .header { background: #1d9e75; padding: 1rem 1.25rem; color: #fff; }
      .header h1 { font-size: 31px; font-weight: 700; margin-bottom: 2px; }
      .header p { font-size: 12px; opacity: 0.9; }
      .prof-badge { display: flex; align-items: center; gap: 10px; padding: 0.85rem 1.25rem; background: #efefec; border-bottom: 1px solid #d5d5d2; }
      .avatar { width: 36px; height: 36px; border-radius: 50%; background: #e1f5ee; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #0f6e56; flex-shrink: 0; }
      .legend { display: flex; gap: 12px; flex-wrap: wrap; padding: 0.7rem 1.25rem; border-bottom: 1px solid #d5d5d2; background: #f3f3f2; }
      .leg-item { display: flex; align-items: center; gap: 5px; font-size: 12px; color: #232323; }
      .leg-dot { width: 10px; height: 10px; border-radius: 50%; }
      .week-block { padding: 1rem 1.25rem; border-bottom: 1px solid #d5d5d2; background: #f3f3f2; }
      .week-label { font-size: 12px; font-weight: 800; color: #1f2937; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 10px; }
      .day-row { display: flex; gap: 6px; margin-bottom: 8px; align-items: flex-start; }
      .day-name { font-size: 13px; font-weight: 600; color: #1f2937; width: 60px; padding-top: 6px; flex-shrink: 0; }
      .sessions { display: flex; gap: 5px; }
      .sess { padding: 5px 12px; border-radius: 20px; font-size: 12px; cursor: pointer; border: 1px solid #c4c0b6; background: #ebe9e4; color: #5f5a50; transition: all 0.15s; user-select: none; }
      .sess[data-statut="present"] { background: #e1f5ee; color: #0f6e56; border-color: #5dcaa5; }
      .sess[data-statut="absent"] { background: #fcebeb; color: #a32d2d; border-color: #f09595; }
      .sess[data-statut="remplacement"] { background: #faeeda; color: #854f0b; border-color: #ef9f27; }
      .summary { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 1rem 1.25rem 0.6rem; background: #f3f3f2; }
      .sum-card { background: #e8e6e1; border-radius: 8px; padding: 0.6rem 0.75rem; text-align: center; }
      .sum-n { font-size: 22px; font-weight: 600; }
      .help-text { text-align: center; font-size: 13px; color: #4b5563; margin: 0.5rem 1.25rem 0.55rem; }
      .save-btn { margin: 0 1.25rem 1rem; display: block; width: calc(100% - 2.5rem); padding: 9px 12px; background: transparent; color: #111827; border: 1px solid #b8b8b3; border-radius: 8px; font-size: 18px; cursor: pointer; font-weight: 700; }
      .save-btn:disabled { color: #6b7280; cursor: not-allowed; }
      #msg-erreur { color: #a32d2d; text-align: center; padding: 0.5rem 1.25rem; font-size: 13px; display: none; }
      #msg-succes { background: #e1f5ee; color: #0f6e56; text-align: center; padding: 1rem; font-size: 14px; border-radius: 8px; display: none; margin: 1rem; }
      .deja-valide { text-align: center; padding: 2rem 1.25rem; color: #888; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div id="loading" style="text-align:center;padding:3rem;color:#888">Chargement...</div>
      <div id="app" style="display:none"></div>
    </div>
    <script type="module">
      import { initUI } from '/src/lib/ui.ts'

      void initUI()
    </script>
  </body>
</html>
