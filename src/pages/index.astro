<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pointage - Ecole de la mosquée Al'Ihsane</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #f5f5f5; min-height: 100vh; }
      .wrap { max-width: 480px; margin: 0 auto; padding: 1rem; }
      .card { background: white; border-radius: 12px; overflow: hidden; margin-bottom: 1rem; border: 0.5px solid #e0e0e0; }
      .header { background: #1D9E75; padding: 1rem 1.25rem; color: white; }
      .header h1 { font-size: 16px; font-weight: 500; margin-bottom: 2px; }
      .header p { font-size: 12px; opacity: 0.85; }
      .prof-badge { display: flex; align-items: center; gap: 10px; padding: 0.75rem 1.25rem; background: #f9f9f9; border-bottom: 0.5px solid #e0e0e0; }
      .avatar { width: 36px; height: 36px; border-radius: 50%; background: #E1F5EE; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 500; color: #0F6E56; flex-shrink: 0; }
      .legend { display: flex; gap: 10px; flex-wrap: wrap; padding: 0.75rem 1.25rem; border-bottom: 0.5px solid #e0e0e0; }
      .leg-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: #888; }
      .leg-dot { width: 10px; height: 10px; border-radius: 50%; }
      .week-block { padding: 1rem 1.25rem; border-bottom: 0.5px solid #e0e0e0; }
      .week-label { font-size: 11px; font-weight: 500; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px; }
      .day-row { display: flex; gap: 6px; margin-bottom: 6px; align-items: flex-start; }
      .day-name { font-size: 12px; color: #888; width: 60px; padding-top: 6px; flex-shrink: 0; }
      .sessions { display: flex; gap: 5px; }
      .sess { padding: 5px 12px; border-radius: 20px; font-size: 12px; cursor: pointer; border: 0.5px solid #ddd; background: #f5f5f5; color: #aaa; transition: all 0.15s; user-select: none; }
      .sess[data-statut="present"] { background: #E1F5EE; color: #0F6E56; border-color: #5DCAA5; }
      .sess[data-statut="absent"] { background: #FCEBEB; color: #A32D2D; border-color: #F09595; }
      .sess[data-statut="remplacement"] { background: #FAEEDA; color: #854F0B; border-color: #EF9F27; }
      .summary { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 1rem 1.25rem; }
      .sum-card { background: #f5f5f5; border-radius: 8px; padding: 0.6rem 0.75rem; text-align: center; }
      .sum-n { font-size: 22px; font-weight: 500; }
      .save-btn { margin: 0 1.25rem 1.25rem; display: block; width: calc(100% - 2.5rem); padding: 12px; background: #1D9E75; color: white; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; font-weight: 500; }
      .save-btn:disabled { background: #aaa; cursor: not-allowed; }
      #msg-erreur { color: #A32D2D; text-align: center; padding: 0.5rem 1.25rem; font-size: 13px; display: none; }
      #msg-succes { background: #E1F5EE; color: #0F6E56; text-align: center; padding: 1rem; font-size: 14px; border-radius: 8px; display: none; margin: 1rem; }
      .deja-valide { text-align: center; padding: 2rem 1.25rem; color: #888; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div id="loading" style="text-align:center;padding:3rem;color:#888">Chargement...</div>
      <div id="app" style="display:none"></div>
    </div>

    <script type="module">
      import { initPointageApp } from '/src/lib/pointage-client.ts'

      void initPointageApp()
    </script>
  </body>
</html>
