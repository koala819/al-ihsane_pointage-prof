---
// Ce bloc s'exécute côté serveur - rien de sensible n'est exposé
import { supabaseServer } from '../lib/supabase-server'
import PointageMainCard from '../components/PointageMainCard.astro'
import PointageValidatedCard from '../components/PointageValidatedCard.astro'
import type { Session, SessionDate, Statut } from '../lib/types'

export const prerender = false

function getWeekendDates(dateDebut: string, dateFin: string): SessionDate[] {
  const toLocalYMD = (date: Date): string => {
    const y = date.getFullYear()
    const m = String(date.getMonth() + 1).padStart(2, '0')
    const d = String(date.getDate()).padStart(2, '0')
    return `${y}-${m}-${d}`
  }

  const dates: SessionDate[] = []
  const current = new Date(`${dateDebut}T00:00:00`)
  const end = new Date(`${dateFin}T00:00:00`)
  while (current <= end) {
    const day = current.getDay()
    if (day === 6 || day === 0) {
      dates.push({
        date: toLocalYMD(current),
        jour: day === 6 ? 'Samedi' : 'Dimanche'
      })
    }
    current.setDate(current.getDate() + 1)
  }
  return dates
}

function buildWeekendBlocks(dates: SessionDate[]) {
  const weekends: { label: string; days: SessionDate[] }[] = []

  for (let i = 0; i < dates.length; i += 2) {
    const days = dates.slice(i, i + 2)
    const first = new Date(`${days[0].date}T00:00:00`)
    const second = days[1] ? new Date(`${days[1].date}T00:00:00`) : null

    const firstDay = first.toLocaleDateString('fr-FR', { day: 'numeric' })
    const firstMonth = first.toLocaleDateString('fr-FR', { month: 'long' })

    const label = second
      ? `Weekend du ${firstDay}-${second.toLocaleDateString('fr-FR', { day: 'numeric' })} ${firstMonth}`
      : `Weekend du ${firstDay} ${firstMonth}`

    weekends.push({ label, days })
  }

  return weekends
}

function formatPeriodeLabel(dateDebut: string, dateFin: string): string {
  const debut = new Date(`${dateDebut}T00:00:00`)
  const fin = new Date(`${dateFin}T00:00:00`)
  const debutTxt = debut.toLocaleDateString('fr-FR', { month: 'short' }).replace('.', '')
  const finTxt = fin.toLocaleDateString('fr-FR', { month: 'long' })
  return `Vacances ${debutTxt}. - ${finTxt} ${fin.getFullYear()}`
}

const token = Astro.url.searchParams.get('token')?.trim() ?? ''
let errorMessage = ''
let pageData: null | {
  prof: { prenom: string; nom: string; niveau?: string | null; valid_form: boolean }
  periode: { nom: string; date_debut: string; date_fin: string }
  pointages: Array<{ date: string; session: Session; statut: Statut }>
  weeks: { label: string; days: SessionDate[] }[]
  periodeLabel: string
  avatar: string
} = null

function normalizeSession(session: string): Session {
  return session === 'apm' ? 'apres_midi' : 'matin'
}

if (!token) {
  errorMessage = 'Lien invalide.'
} else {
  const { data: prof, error } = await supabaseServer
    .schema('paie')
    .from('profs')
    .select('id, nom, prenom, niveau, valid_form')
    .eq('token', token)
    .maybeSingle()

  if (error || !prof) {
    errorMessage = 'Prof introuvable'
  } else {
    const { data: periode, error: periodeError } = await supabaseServer
      .schema('paie')
      .from('periodes')
      .select('id, nom, date_debut, date_fin')
      .eq('actif', true)
      .maybeSingle()

    if (periodeError || !periode) {
      errorMessage = 'Période introuvable'
    } else {
      const { data: pointages, error: pointagesError } = await supabaseServer
        .schema('paie')
        .from('pointages')
        .select('date, session, statut')
        .eq('prof_id', prof.id)
        .eq('periode', periode.id)
        .order('date', { ascending: true })

      if (pointagesError) {
        errorMessage = 'Erreur lors de la récupération des pointages'
      } else {
        pageData = {
          prof,
          periode,
          pointages: (pointages ?? []).map((p) => ({
            ...p,
            session: normalizeSession(p.session)
          })),
          weeks: buildWeekendBlocks(getWeekendDates(periode.date_debut, periode.date_fin)),
          periodeLabel: formatPeriodeLabel(periode.date_debut, periode.date_fin),
          avatar: `${prof.prenom[0] ?? ''}${prof.nom[0] ?? ''}`.toUpperCase()
        }
      }
    }
  }
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pointage des cours - Al'Ihsane</title>
    <style is:global>
      :root { color-scheme: light; }
      html { -webkit-text-size-adjust: 100%; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #efefef; min-height: 100dvh; color: #1f2937; }
      .wrap { width: 100%; max-width: min(32rem, 100%); margin: 0 auto; padding: max(0.75rem, env(safe-area-inset-top, 0px)) max(0.75rem, env(safe-area-inset-right, 0px)) max(0.75rem, env(safe-area-inset-bottom, 0px)) max(0.75rem, env(safe-area-inset-left, 0px)); }
      @media (min-width: 40rem) { .wrap { padding: 1.25rem; } }
      .card { background: #f3f3f2; border-radius: 10px; overflow: hidden; border: 1px solid #d5d5d2; width: 100%; }
      .header { background: #1d9e75; padding: 1rem min(1.25rem, 4vw); color: #fff; }
      .header h1 { font-size: clamp(1.25rem, 5vw, 1.9rem); font-weight: 700; margin-bottom: 2px; line-height: 1.2; }
      .header p { font-size: 0.75rem; opacity: 0.9; }
      .prof-badge { display: flex; align-items: center; gap: 10px; padding: 0.85rem min(1.25rem, 4vw); background: #efefec; border-bottom: 1px solid #d5d5d2; }
      .avatar { width: 36px; height: 36px; border-radius: 50%; background: #e1f5ee; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #0f6e56; flex-shrink: 0; }
      .legend { display: flex; gap: 0.75rem; flex-wrap: wrap; padding: 0.7rem min(1.25rem, 4vw); border-bottom: 1px solid #d5d5d2; background: #f3f3f2; }
      .leg-item { display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: #232323; }
      .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
      .week-block { padding: 1rem min(1.25rem, 4vw); border-bottom: 1px solid #d5d5d2; background: #f3f3f2; }
      .week-label { font-size: 0.75rem; font-weight: 800; color: #1f2937; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 0.75rem; line-height: 1.3; }
      .day-row { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.75rem; align-items: stretch; }
      @media (min-width: 23rem) {
        .day-row { flex-direction: row; align-items: flex-start; gap: 0.5rem; }
      }
      .day-name { font-size: 0.8125rem; font-weight: 600; color: #1f2937; width: 100%; flex-shrink: 0; }
      @media (min-width: 23rem) { .day-name { width: 3.75rem; padding-top: 0.5rem; } }
      .sessions { display: flex; flex-wrap: wrap; gap: 0.4rem; width: 100%; min-width: 0; }
      .sess {
        min-height: 2.75rem; /* ~44px zone tactile */
        min-width: 0;
        flex: 1 1 calc(50% - 0.2rem);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 0.35rem 0.5rem;
        border-radius: 1.25rem;
        font-size: clamp(0.6875rem, 2.8vw, 0.75rem);
        line-height: 1.2;
        cursor: pointer;
        border: 1px solid #c4c0b6;
        background: #ebe9e4;
        color: #5f5a50;
        transition: background-color 0.15s, color 0.15s, border-color 0.15s;
        user-select: none;
        -webkit-appearance: none;
        appearance: none;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        position: relative;
        z-index: 1;
      }
      .sess[data-statut="present"] { background: #e1f5ee; color: #0f6e56; border-color: #5dcaa5; }
      .sess[data-statut="absent"] { background: #fcebeb; color: #a32d2d; border-color: #f09595; }
      .sess[data-statut="remplacement"] { background: #faeeda; color: #854f0b; border-color: #ef9f27; }
      .summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; padding: 1rem min(1.25rem, 4vw) 0.6rem; background: #f3f3f2; }
      @media (max-width: 22rem) { .summary { grid-template-columns: 1fr; } }
      .sum-card { background: #e8e6e1; border-radius: 8px; padding: 0.5rem min(0.75rem, 3vw); text-align: center; min-width: 0; }
      .sum-n { font-size: clamp(1.1rem, 4.5vw, 1.35rem); font-weight: 600; }
      .help-text { text-align: center; font-size: 13px; color: #4b5563; margin: 0.5rem 1.25rem 0.55rem; }
      .save-btn {
        margin: 0 min(1.25rem, 4vw) 1rem;
        display: block;
        width: calc(100% - 2 * min(1.25rem, 4vw));
        min-height: 2.75rem;
        padding: 0.7rem 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f4f4f2 100%);
        color: #111827;
        border: 1px solid #b8b8b3;
        border-radius: 10px;
        font-size: clamp(1rem, 4vw, 1.125rem);
        font-weight: 700;
        letter-spacing: 0.01em;
        cursor: pointer;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        transition: transform 0.08s ease, box-shadow 0.16s ease, background-color 0.16s ease;
        box-shadow: 0 1px 1px rgba(17, 24, 39, 0.06);
      }
      .save-btn:hover {
        background: #ffffff;
        box-shadow: 0 3px 10px rgba(17, 24, 39, 0.08);
      }
      .save-btn:active {
        transform: translateY(1px);
        box-shadow: 0 1px 3px rgba(17, 24, 39, 0.08);
      }
      .save-btn:focus-visible {
        outline: 3px solid rgba(29, 158, 117, 0.25);
        outline-offset: 2px;
      }
      .save-btn:disabled {
        color: #6b7280;
        background: #ececea;
        border-color: #cfcfcb;
        box-shadow: none;
        cursor: not-allowed;
        transform: none;
      }
      #msg-erreur { color: #a32d2d; text-align: center; padding: 0.5rem 1.25rem; font-size: 13px; display: none; }
      #msg-succes { background: #e1f5ee; color: #0f6e56; text-align: center; padding: 1rem; font-size: 14px; border-radius: 8px; display: none; margin: 1rem; }
      .deja-valide { text-align: center; padding: 2rem 1.25rem; color: #888; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      {
        errorMessage ? (
          <div class="card">
            <div class="header">
              <h1>Erreur</h1>
              <p>Pointage des cours</p>
            </div>
            <div class="deja-valide">{errorMessage}</div>
          </div>
        ) : pageData?.prof.valid_form ? (
          <PointageValidatedCard periodeLabel={`Période ${pageData.periode.nom}`} />
        ) : (
          <PointageMainCard
            token={token}
            periodeLabel={pageData!.periode.nom}
            profName={`${pageData!.prof.prenom} ${pageData!.prof.nom}`}
            profLevel={`niveau ${pageData!.prof.niveau ?? ''}`}
            avatar={pageData!.avatar}
            weeks={pageData!.weeks}
            initialStatuts={Object.fromEntries(
              pageData!.pointages.map((p) => [`${p.date}_${p.session}`, p.statut])
            )}
          />
        )
      }
    </div>
    {
      !errorMessage && !pageData?.prof.valid_form && (
        <script>
          import '../lib/pointage-controller.ts'
        </script>
      )
    }
  </body>
</html>
