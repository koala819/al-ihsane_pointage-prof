---
import { supabaseServer } from '../lib/supabase-server'

export const prerender = false

const accessToken = Astro.url.searchParams.get('token')?.trim() ?? ''
const expectedToken = (import.meta.env.RECAP_TOKEN ?? '').trim()
const isAllowed = Boolean(expectedToken) && accessToken === expectedToken

type ProfSummary = {
  nom: string
  nomUpper: string
  prenom: string
  totalCours: number
  montant: number
}

let periodeLabel = ''
let rowsAvecSaisie: ProfSummary[] = []
let rowsSansSaisie: ProfSummary[] = []
let errorMessage = ''

if (isAllowed) {
  const { data: periode, error: periodeError } = await supabaseServer
    .schema('paie')
    .from('periodes')
    .select('id, nom')
    .eq('actif', true)
    .maybeSingle()

  if (periodeError || !periode) {
    errorMessage = 'Periode active introuvable.'
  } else {
    periodeLabel = periode.nom

    const { data: profs, error: profsError } = await supabaseServer
      .schema('paie')
      .from('profs')
      .select('id, nom, prenom')
      .order('nom', { ascending: true })
      .order('prenom', { ascending: true })

    if (profsError || !profs) {
      errorMessage = 'Impossible de recuperer la liste des profs.'
    } else {
      const { data: pointages, error: pointagesError } = await supabaseServer
        .schema('paie')
        .from('pointages')
        .select('prof_id, statut')
        .eq('periode', periode.id)
        .in('statut', ['present', 'remplacement'])

      if (pointagesError || !pointages) {
        errorMessage = 'Impossible de recuperer les pointages.'
      } else {
        const totalsByProf = new Map<number, number>()
        for (const p of pointages) {
          const current = totalsByProf.get(p.prof_id) ?? 0
          totalsByProf.set(p.prof_id, current + 1)
        }

        const sorted = profs
          .map((prof) => {
            const totalCours = totalsByProf.get(prof.id) ?? 0
            return {
              nom: prof.nom,
              nomUpper: prof.nom.toLocaleUpperCase('fr-FR'),
              prenom: prof.prenom,
              totalCours,
              montant: totalCours * 30
            }
          })
          .sort((a, b) => {
            const byNom = a.nom.localeCompare(b.nom, 'fr', { sensitivity: 'base' })
            if (byNom !== 0) return byNom
            return a.prenom.localeCompare(b.prenom, 'fr', { sensitivity: 'base' })
          })
        rowsAvecSaisie = sorted.filter((r) => r.totalCours > 0)
        rowsSansSaisie = sorted.filter((r) => r.totalCours === 0)
      }
    }
  }
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recapitulatif profs</title>
    <style>
      :root { color-scheme: light; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: #efefef;
        color: #1f2937;
        min-height: 100dvh;
      }
      .wrap {
        width: 100%;
        max-width: 52rem;
        margin: 0 auto;
        padding: 0.85rem;
      }
      .card {
        background: #f3f3f2;
        border: 1px solid #d5d5d2;
        border-radius: 10px;
        overflow: hidden;
      }
      .header {
        background: #1d9e75;
        color: #fff;
        padding: 0.95rem 1rem;
      }
      .header h1 {
        font-size: clamp(1.1rem, 4.6vw, 1.5rem);
        line-height: 1.2;
      }
      .header p {
        margin-top: 0.2rem;
        font-size: 0.78rem;
        opacity: 0.92;
      }
      .error {
        padding: 1rem;
        color: #a32d2d;
        font-weight: 600;
      }
      .list {
        padding: 0.6rem;
        display: grid;
        gap: 0.5rem;
      }
      .row {
        background: #eceae5;
        border: 1px solid #d6d3cc;
        border-radius: 8px;
        padding: 0.65rem 0.75rem;
        display: grid;
        gap: 0.35rem;
      }
      .name {
        font-weight: 700;
        font-size: 0.95rem;
      }
      .meta {
        display: flex;
        justify-content: space-between;
        gap: 0.8rem;
        font-size: 0.85rem;
        color: #3f3f46;
      }
      .amount {
        font-weight: 700;
        color: #0f6e56;
      }
      .empty {
        padding: 1rem;
        color: #6b7280;
      }
      .content {
        padding: 0.6rem;
        display: flex;
        flex-direction: column;
        gap: 1.15rem;
      }
      .section {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .section-title {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #57534e;
        font-weight: 700;
        padding: 0 0.15rem;
      }
      .section-title strong {
        font-weight: 800;
        color: #1c1917;
      }
      .section-hint {
        font-size: 0.78rem;
        color: #78716c;
        padding: 0 0.15rem 0.15rem;
        line-height: 1.35;
      }
      .section-empty {
        padding: 0.55rem 0.75rem;
        color: #78716c;
        font-size: 0.85rem;
        font-style: italic;
        background: #f5f4f0;
        border: 1px dashed #d6d3cd;
        border-radius: 8px;
      }
      .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #c4c0b8 18%, #c4c0b8 82%, transparent);
        margin: 0.15rem 0;
      }
      .row--sans-saisie {
        background: #f8f7f4;
        border-color: #e0ddd6;
      }
      .row--sans-saisie .amount {
        color: #78716c;
      }
      @media (min-width: 640px) {
        .wrap { padding: 1.25rem; }
        .row {
          grid-template-columns: 1fr auto auto;
          align-items: center;
          gap: 1rem;
        }
        .meta { display: contents; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      {
        !isAllowed ? (
          <div class="card">
            <div class="header">
              <h1>Acces refuse</h1>
              <p>Token invalide.</p>
            </div>
          </div>
        ) : (
          <div class="card">
            <div class="header">
              <h1>Recapitulatif des profs</h1>
              <p>{periodeLabel ? `Periode ${periodeLabel}` : 'Periode active'}</p>
            </div>
            {
              errorMessage ? (
                <div class="error">{errorMessage}</div>
              ) : rowsAvecSaisie.length === 0 && rowsSansSaisie.length === 0 ? (
                <div class="empty">Aucune donnee a afficher.</div>
              ) : (
                <div class="content">
                  <div class="section">
                    <div class="section-title">
                      <strong>{rowsAvecSaisie.length}</strong> Enseignants avec saisie effectuée
                    </div>
                    {
                      rowsAvecSaisie.length === 0 ? (
                        <div class="section-empty">Aucun prof avec pointage pour cette periode.</div>
                      ) : (
                        <div class="list">
                          {
                            rowsAvecSaisie.map((row) => (
                              <div class="row">
                                <div class="name">{row.nomUpper} {row.prenom}</div>
                                <div class="meta">
                                  <span>{row.totalCours} cours</span>
                                  <span class="amount">{row.montant} EUR</span>
                                </div>
                              </div>
                            ))
                          }
                        </div>
                      )
                    }
                  </div>
                  <div class="divider" aria-hidden="true" />
                  <div class="section">
                    <div class="section-title">
                      <strong>{rowsSansSaisie.length}</strong> Enseignants sans saisie
                    </div>
                    {
                      rowsSansSaisie.length === 0 ? (
                        <div class="section-empty">Tous les profs ont au moins une saisie.</div>
                      ) : (
                        <div class="list">
                          {
                            rowsSansSaisie.map((row) => (
                              <div class="row row--sans-saisie">
                                <div class="name">{row.nomUpper} {row.prenom}</div>
                                <div class="meta">
                                  <span>0 cours</span>
                                  <span class="amount">0 EUR</span>
                                </div>
                              </div>
                            ))
                          }
                        </div>
                      )
                    }
                  </div>
                </div>
              )
            }
          </div>
        )
      }
    </div>
  </body>
</html>
